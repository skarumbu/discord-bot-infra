# Terraform state files — never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform working directories
**/.terraform/
**/.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Sensitive variable files — pass secrets via TF_VAR_* env vars instead
*.tfvars.json
# Note: terraform.tfvars IS committed here (non-secret values only)
# Secret vars (subscription_id, discord_token) must use TF_VAR_* env vars

# Override files (local developer overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files (may contain sensitive values)
*.tfplan

# CLI configuration
.terraformrc
terraform.rc
